{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lunex",
  "version": "0.1.1",
  "identifier": "com.lunex.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://raw.githubusercontent.com/miangee21/Lunex/master/updater.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQxRjk4RjQxNkJEOUI1NUQKUldSZHRkbHJRWS81UVhKOFdVYno2citkdzhrSkprSGdQNHFBK1o0WlQ3NlYwY0xEbE9DRzdTblMK"
    }
  },
  "app": {
    "windows": [
      {
        "title": "Lunex",
        "width": 800,
        "height": 600,
        "devtools": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    }
  }
}
